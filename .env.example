# ──────────────────────────────────────────────────────────────────────────
# RatioVault backend (FastAPI) — example env file
# Copy to `api/.env` and fill in real values for local development.
# All subscription-related vars default to empty string in code so endpoints
# fail closed when a secret is missing.
# ──────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────
PORT=8000
HOST=0.0.0.0
LOG_LEVEL=INFO

# ── CORS (comma-separated list of allowed origins) ────────────────────────
CORS_ORIGINS=http://localhost:5173,http://localhost:5174,http://localhost:3000

# ── SEC EDGAR (yfinance/SEC require a real UA — app crashes on default) ──
SEC_USER_AGENT=RatioVault contact@yourdomain.com

# ── Chart cache ───────────────────────────────────────────────────────────
CHART_CACHE_TTL=300
CHART_CACHE_MAX_SIZE=100

# ── Supabase (service-role + JWT verification) ────────────────────────────
# SUPABASE_URL: https://<project-ref>.supabase.co
# SUPABASE_SERVICE_ROLE_KEY: service_role key from Supabase dashboard (KEEP SECRET)
# SUPABASE_JWT_SECRET: JWT secret used to verify user access tokens
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ── Internal cron auth (retention endpoint fails closed if empty) ─────────
# Shared secret sent as `X-Internal-Token` by the cron scheduler.
INTERNAL_CRON_TOKEN=

# ── Lemon Squeezy ─────────────────────────────────────────────────────────
# LEMON_SQUEEZY_WEBHOOK_SECRET: signing secret for HMAC-SHA256 webhook verification
# LEMON_SQUEEZY_STORE_ID: numeric store id
# LEMON_SQUEEZY_CHECKOUT_BASE: base URL for hosted checkout (e.g. https://ratiovault.lemonsqueezy.com)
# LEMON_SQUEEZY_MONTHLY_VARIANT_ID / LEMON_SQUEEZY_YEARLY_VARIANT_ID: price variants
# LEMON_SQUEEZY_API_KEY: server-side API key for customer-portal links + subscription mgmt
LEMON_SQUEEZY_WEBHOOK_SECRET=
LEMON_SQUEEZY_STORE_ID=
LEMON_SQUEEZY_CHECKOUT_BASE=
LEMON_SQUEEZY_MONTHLY_VARIANT_ID=
LEMON_SQUEEZY_YEARLY_VARIANT_ID=
LEMON_SQUEEZY_API_KEY=
